# MongoDB Connection (Local Database)
MONGO_URI=mongodb://127.0.0.1:27017/carenest
# Optional (for Atlas SRV DNS issues on some Windows setups)
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_key

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Payment Gateway Configuration
# Use "mock" for local simulated checkout or "sslcommerz" for real gateway
PAYMENT_GATEWAY_MODE=mock

# Public backend URL used by gateway callbacks
SERVER_PUBLIC_URL=http://localhost:5000

# SSLCommerz credentials (required when PAYMENT_GATEWAY_MODE=sslcommerz)
SSL_IS_LIVE=false
SSL_STORE_ID=
SSL_STORE_PASSWORD=
